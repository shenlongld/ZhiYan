# RAGFlow Configuration
RAGFLOW_HOST=http://localhost:9380
RAGFLOW_API_KEY=your_ragflow_api_key_here

# RAGFlow embedding model（用于 create_dataset）
RAGFLOW_EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5@BAAI

# 外接大模型问答：提示词模板文件路径（相对于 backend 根目录）
RAGFLOW_QA_PROMPT_PATH=app/prompts/external_qa_prompt.txt

# RAGFlow Q&A LLM（用于 create_chat / ask）
# 支持 OpenAI 兼容 API（例如 OpenAI / Azure OpenAI / 各类兼容网关）
RAGFLOW_LLM_MODEL=gpt-4o-mini
RAGFLOW_LLM_API_KEY=your_llm_api_key_here
RAGFLOW_LLM_BASE_URL=https://api.openai.com/v1
RAGFLOW_LLM_TEMPERATURE=0.1
RAGFLOW_LLM_MAX_TOKENS=2048

# 检索结果取前 N 条作为 context
RAGFLOW_RETRIEVE_TOP_K=5

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=true
